# 로컬 개발 환경
# Vite dev server가 /api/* 요청을 이 주소로 프록시
VITE_API_TARGET=http://localhost:3000

# 클라이언트에서 직접 호출할 API Base URL (배포 빌드 시 사용)
# 예: https://api.taskr.it
VITE_API_BASE=/api

# Chat API / WebSocket
VITE_CHAT_API_TARGET=http://localhost:3001
VITE_CHAT_WS_TARGET=ws://localhost:3001
VITE_CHAT_API_BASE=/chat-api
VITE_CHAT_WS_BASE=ws://localhost:3001/ws
